rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    // Anyone signed in can read any user profile (needed for matching).
    // Only the profile owner can write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Conversations ──
    // A participant can read/write their own conversation doc.
    match /conversations/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // ── Messages sub-collection ──
      // Only participants of the parent conversation can read/write messages.
      match /messages/{msgId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                      && request.resource.data.from == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Friends ──
    match /friends/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
  }
}
